# Salin file ini ke .env dan isi nilainya
# cp .env.example .env

# Password untuk akses panel admin
ADMIN_PASSWORD=gantiPasswordIni

# Port untuk Express API server (default: 3001)
PORT=3001

# Database (libsql / Turso)
# Lokal: biarkan default (file:data.db) atau tulis eksplisit seperti di bawah
TURSO_DATABASE_URL=file:data.db
# TURSO_AUTH_TOKEN=   # tidak diperlukan untuk mode file lokal

# Produksi Vercel — ganti dengan URL dan token dari dashboard Turso
# TURSO_DATABASE_URL=libsql://nama-db-anda.turso.io
# TURSO_AUTH_TOKEN=eyJhbGci...
